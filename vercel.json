{
  "version": 2,
  "buildCommand": "npm install && cd ikki_frontend && npm install && npm run build",
  "outputDirectory": "ikki_frontend/dist",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
