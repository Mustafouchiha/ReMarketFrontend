{
  "version": 2,
  "buildCommand": "npm install && cd ikki_frontend && npm install && npm run build",
  "outputDirectory": "ikki_frontend/dist",
  "framework": null,
  "functions": {
    "api/[...path].js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
